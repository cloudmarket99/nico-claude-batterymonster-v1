---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../data/business';
import { serviceTypes } from '../data/serviceTypes';
import { serviceAreas } from '../data/serviceAreas';
import { serviceUrl, areaUrl, contactUrl, casesUrl } from '../lib/urls';
import { reviews } from '../data/seoContent';
import { cases } from '../data/cases';

const latestCases = cases.slice(0, 3);

const years = yearsInBusiness();

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${business.website}/#website`,
      url: business.website,
      name: business.name,
      description: business.description,
      publisher: { '@id': `${business.website}/#business` },
    },
    {
      '@type': 'ElectricalContractor',
      '@id': `${business.website}/#business`,
      name: business.name,
      legalName: business.legalName,
      url: business.website,
      telephone: business.phone,
      email: business.email,
      description: business.description,
      founder: {
        '@type': 'Person',
        name: business.owner,
      },
      foundingDate: `${business.yearEstablished}`,
      address: {
        '@type': 'PostalAddress',
        streetAddress: business.address.street,
        addressLocality: business.address.city,
        addressRegion: business.address.state,
        postalCode: business.address.zip,
        addressCountry: 'KR',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: business.coordinates.lat,
        longitude: business.coordinates.lng,
      },
      areaServed: serviceAreas.map((area) => ({
        '@type': 'City',
        name: area.name,
        containedInPlace: {
          '@type': 'AdministrativeArea',
          name: area.county,
        },
      })),
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: '산업용 배터리 서비스',
        itemListElement: serviceTypes.map((service) => ({
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: service.name,
            description: service.shortDescription,
          },
        })),
      },
    },
    {
      '@type': 'WebPage',
      '@id': `${business.website}/#webpage`,
      url: business.website,
      name: `${business.name} | 전국 산업용 배터리 설치 전문`,
      isPartOf: { '@id': `${business.website}/#website` },
      about: { '@id': `${business.website}/#business` },
      description: business.description,
    },
  ],
};
---

<BaseLayout
  title={`${business.name} | 전국 산업용 배터리 설치 전문`}
  description={business.description}
  schema={schema}
>
  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-900 to-brand-800">
    <div class="absolute inset-0">
      <img
        src="/images/hero.webp"
        alt="산업용 배터리 설치 전문가가 작업하는 모습"
        class="h-full w-full object-cover opacity-20"
        width="2048"
        height="2048"
        loading="eager"
      />
    </div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(249,115,22,0.15),_transparent_70%)]" />

    <div class="relative mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
      <div class="max-w-2xl animate-fade-up">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand-800/60 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-300">
          <Icon name="lucide:zap" class="size-3.5" />
          전국 산업용 배터리 설치 전문
        </div>
        <h1 class="font-display text-4xl text-white sm:text-5xl lg:text-6xl">
          밧데리몬스터 max
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-brand-200">
          {business.tagline}. 지게차 배터리, UPS, ESS, 비상발전기 배터리 등 모든 산업용 배터리를
          {business.serviceRadius}에 전문 기사가 직접 설치합니다. {years}년 이상의 경험과 전기공사업 면허 보유.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-6 py-3 text-sm font-semibold text-brand-950 shadow-lg transition-all hover:bg-amber-400 hover:shadow-xl"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone} 전화상담
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition-all hover:bg-white/20"
          >
            <Icon name="lucide:message-square" class="size-5" />
            무료 견적 문의
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS BAR ============ -->
  <section class="bg-brand-950">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-px sm:grid-cols-4">
      {[
        { icon: 'lucide:award', label: `${years}년 이상 경력` },
        { icon: 'lucide:shield-check', label: '전기공사업 면허 보유' },
        { icon: 'lucide:clock', label: '24시간 긴급 출동' },
        { icon: 'lucide:map-pin', label: '전국 서비스 가능' },
      ].map((stat) => (
        <div class="flex items-center justify-center gap-3 bg-brand-950 px-4 py-5">
          <Icon name={stat.icon} class="size-5 shrink-0 text-amber-400" />
          <span class="text-sm font-medium text-white">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ SERVICES GRID ============ -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl text-brand-900 sm:text-4xl">
          산업용 배터리 전문 서비스
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-stone-600">
          지게차 배터리부터 UPS, ESS, 비상발전기까지 모든 산업용 배터리 설치와 교체를
          전문 기사가 안전하게 처리합니다.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {serviceTypes.map((service, i) => (
          <a
            href={serviceUrl(service.slug)}
            class={`card-hover group relative rounded-xl border border-stone-200 bg-white p-6 animate-fade-up stagger-${Math.min(i + 1, 6)}`}
          >
            {service.emergency && (
              <span class="absolute right-4 top-4 inline-flex items-center gap-1 rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-semibold text-amber-700">
                <Icon name="lucide:zap" class="size-3" />
                24/7
              </span>
            )}
            <div class="flex size-12 items-center justify-center rounded-lg bg-brand-50 text-brand-700 transition-colors group-hover:bg-brand-100">
              <Icon name={service.icon} class="size-6" />
            </div>
            <h3 class="mt-4 font-display text-lg text-brand-900">
              {service.name}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">
              {service.shortDescription}
            </p>
            <p class="mt-3 text-sm font-semibold text-brand-700">
              {service.priceRange.min.toLocaleString()}원부터
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ RECENT CASES ============ -->
  <section class="bg-stone-50 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="flex flex-col items-end justify-between gap-4 sm:flex-row sm:items-center">
        <div class="max-w-xl">
          <h2 class="font-display text-3xl text-brand-900 sm:text-4xl">
            최신 시공 사례
          </h2>
          <p class="mt-4 text-stone-600">
            현장별 맞춤 솔루션으로 완벽하게 시공된 최신 배터리 설치 사례를 확인해보세요.
          </p>
        </div>
        <a 
          href="/cases/"
          class="inline-flex items-center gap-2 text-sm font-semibold text-brand-700 transition-colors hover:text-brand-900"
        >
          시공사례 전체보기
          <Icon name="lucide:arrow-right" class="size-4" />
        </a>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {latestCases.map((item, i) => (
          <a
            href={casesUrl(item.slug)}
            class={`group overflow-hidden rounded-xl border border-stone-200 bg-white transition-all hover:shadow-xl animate-fade-up stagger-${i + 1}`}
          >
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={item.thumbnail}
                alt={item.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                width="800"
                height="500"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <div class="mb-3 flex flex-wrap gap-2">
                <span class="inline-flex items-center rounded-full bg-brand-50 px-2.5 py-0.5 text-[11px] font-semibold text-brand-700">
                  {item.category}
                </span>
                <span class="inline-flex items-center rounded-full bg-stone-100 px-2.5 py-0.5 text-[11px] font-medium text-stone-600">
                  {item.location}
                </span>
              </div>
              <h3 class="font-display text-lg leading-tight text-brand-900 group-hover:text-brand-700">
                {item.title}
              </h3>
              <div class="mt-4 flex items-center justify-between border-t border-stone-100 pt-4">
                <span class="text-xs font-medium text-stone-400">{item.model}</span>
                <span class="inline-flex items-center gap-1 text-xs font-bold text-brand-600">
                  자세히 보기
                  <Icon name="lucide:chevron-right" class="size-3" />
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW WE WORK ============ -->
  <section class="bg-brand-950 py-16 lg:py-24" id="how-we-work">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="text-center">
        <span class="inline-flex items-center gap-2 rounded-full bg-brand-900 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-300">
          <Icon name="lucide:settings" class="size-3.5" />
          간편한 프로세스
        </span>
        <h2 class="mt-4 font-display text-3xl text-white sm:text-4xl">
          서비스 진행 방법
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-brand-300">
          전화 한 통으로 시작해서 설치 완료까지 모든 과정을 투명하게 진행합니다.
        </p>
      </div>

      <div class="mt-14 lg:flex lg:gap-10">
        <div class="flex gap-2 overflow-x-auto pb-4 lg:w-80 lg:shrink-0 lg:flex-col lg:gap-0 lg:overflow-visible lg:pb-0">
          {[
            {
              step: 1,
              title: '전화 또는 문의',
              icon: 'lucide:phone-call',
              summary: '증상과 배터리 정보를 알려주세요.',
              detail: `${business.phone}으로 전화하거나 온라인 문의를 남겨주세요. 배터리 종류, 모델, 증상을 알려주시면 즉시 상담해드리고 방문 일정을 잡아드립니다. 긴급 상황은 즉시 출동합니다.`,
              image: '/images/hero.webp',
            },
            {
              step: 2,
              title: '현장 진단 및 견적',
              icon: 'lucide:search',
              summary: '전문 장비로 정확히 진단하고 견적을 제시합니다.',
              detail: '전문 기사가 현장에 방문해 배터리 상태를 정밀 진단합니다. 전압, 용량, 내부 저항을 측정하고 교체 필요 여부와 최적 배터리 사양을 확인한 후 투명한 견적서를 제공합니다.',
              image: '/images/industrial-battery.webp',
            },
            {
              step: 3,
              title: '전문 설치 작업',
              icon: 'lucide:wrench',
              summary: '전기공사업 면허 기사가 안전하게 설치합니다.',
              detail: '고객 승인 후 전기공사업 면허 보유 전문 기사가 안전 기준에 따라 배터리를 교체하거나 설치합니다. 모든 작업은 관련 법규와 안전 수칙을 준수합니다.',
              image: '/images/forklift-battery.webp',
            },
            {
              step: 4,
              title: '테스트 및 사후 관리',
              icon: 'lucide:check-circle',
              summary: '설치 후 성능 테스트와 6개월 A/S를 보장합니다.',
              detail: '설치 완료 후 충방전 테스트를 실시하고 정상 동작을 확인합니다. 올바른 배터리 관리 방법을 안내하며, 6개월 무상 A/S를 제공합니다.',
              image: '/images/ups-battery.webp',
            },
          ].map((item, i) => (
            <button
              type="button"
              class={`hww-tab group flex w-64 shrink-0 items-start gap-4 rounded-xl px-5 py-4 text-left transition-all lg:w-full ${i === 0 ? 'bg-brand-800/80 ring-1 ring-brand-600/40' : 'hover:bg-brand-900'}`}
              data-step={item.step}
              data-title={item.title}
              data-detail={item.detail}
              data-image={item.image}
            >
              <div class={`flex size-10 shrink-0 items-center justify-center rounded-lg transition-colors ${i === 0 ? 'bg-amber-500 text-brand-950' : 'bg-brand-800 text-brand-400 group-hover:bg-brand-700'}`}>
                <Icon name={item.icon} class="size-5" />
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <span class={`text-xs font-bold ${i === 0 ? 'text-amber-400' : 'text-brand-500'}`}>Step {item.step}</span>
                </div>
                <h3 class={`mt-0.5 text-sm font-semibold ${i === 0 ? 'text-white' : 'text-brand-200'}`}>
                  {item.title}
                </h3>
                <p class={`mt-1 text-xs leading-relaxed ${i === 0 ? 'text-brand-300' : 'text-brand-400'}`}>
                  {item.summary}
                </p>
              </div>
            </button>
          ))}
        </div>

        <div class="mt-8 flex-1 lg:mt-0">
          <div class="relative overflow-hidden rounded-2xl">
            <img
              id="hww-image"
              src="/images/hero.webp"
              alt="Step 1: 전화 또는 문의"
              class="h-64 w-full object-cover sm:h-80 lg:h-96 transition-opacity duration-300"
              width="1408"
              height="768"
            />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-brand-950/90 via-brand-950/60 to-transparent px-6 pb-6 pt-20 sm:px-8 sm:pb-8 sm:pt-28">
              <div class="flex items-center gap-3">
                <span class="flex size-8 items-center justify-center rounded-full bg-amber-500 text-sm font-bold text-brand-950" id="hww-step-num">1</span>
                <h3 class="font-display text-xl text-white sm:text-2xl" id="hww-title">전화 또는 문의</h3>
              </div>
              <p class="mt-3 max-w-xl text-sm leading-relaxed text-brand-200 sm:text-base" id="hww-detail">
                {business.phone}으로 전화하거나 온라인 문의를 남겨주세요. 배터리 종류, 모델, 증상을 알려주시면 즉시 상담해드리고 방문 일정을 잡아드립니다. 긴급 상황은 즉시 출동합니다.
              </p>
            </div>
          </div>

          <div class="mt-4 flex items-center justify-center gap-2 lg:justify-start">
            {[1, 2, 3, 4].map((n) => (
              <button
                type="button"
                class={`hww-dot size-2.5 rounded-full transition-all ${n === 1 ? 'bg-amber-500 w-8' : 'bg-brand-700 hover:bg-brand-600'}`}
                data-dot={n}
                aria-label={`Step ${n}으로 이동`}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.hww-tab');
    const dots = document.querySelectorAll<HTMLButtonElement>('.hww-dot');
    const image = document.getElementById('hww-image') as HTMLImageElement;
    const stepNum = document.getElementById('hww-step-num');
    const title = document.getElementById('hww-title');
    const detail = document.getElementById('hww-detail');

    function activateStep(step: number) {
      const tab = Array.from(tabs).find(t => Number(t.dataset.step) === step);
      if (!tab || !image || !stepNum || !title || !detail) return;

      tabs.forEach(t => {
        const isActive = t === tab;
        t.classList.toggle('bg-brand-800/80', isActive);
        t.classList.toggle('ring-1', isActive);
        t.classList.toggle('ring-brand-600/40', isActive);
        t.classList.toggle('hover:bg-brand-900', !isActive);

        const icon = t.querySelector('div:first-child') as HTMLElement;
        if (icon) {
          icon.classList.toggle('bg-amber-500', isActive);
          icon.classList.toggle('text-brand-950', isActive);
          icon.classList.toggle('bg-brand-800', !isActive);
          icon.classList.toggle('text-brand-400', !isActive);
          icon.classList.toggle('group-hover:bg-brand-700', !isActive);
        }

        const stepLabel = t.querySelector('span:first-of-type') as HTMLElement;
        if (stepLabel) {
          stepLabel.classList.toggle('text-amber-400', isActive);
          stepLabel.classList.toggle('text-brand-500', !isActive);
        }

        const h3 = t.querySelector('h3') as HTMLElement;
        if (h3) {
          h3.classList.toggle('text-white', isActive);
          h3.classList.toggle('text-brand-200', !isActive);
        }

        const p = t.querySelector('p') as HTMLElement;
        if (p) {
          p.classList.toggle('text-brand-300', isActive);
          p.classList.toggle('text-brand-400', !isActive);
        }
      });

      dots.forEach(d => {
        const isActive = Number(d.dataset.dot) === step;
        d.classList.toggle('bg-amber-500', isActive);
        d.classList.toggle('w-8', isActive);
        d.classList.toggle('bg-brand-700', !isActive);
      });

      image.style.opacity = '0';
      setTimeout(() => {
        image.src = tab.dataset.image || '';
        image.alt = `Step ${step}: ${tab.dataset.title}`;
        image.style.opacity = '1';
      }, 150);

      stepNum.textContent = String(step);
      title.textContent = tab.dataset.title || '';
      detail.textContent = tab.dataset.detail || '';
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => activateStep(Number(tab.dataset.step)));
    });

    dots.forEach(dot => {
      dot.addEventListener('click', () => activateStep(Number(dot.dataset.dot)));
    });

    let currentStep = 1;
    let autoTimer = setInterval(() => {
      currentStep = currentStep >= 4 ? 1 : currentStep + 1;
      activateStep(currentStep);
    }, 6000);

    const section = document.getElementById('how-we-work');
    section?.addEventListener('click', () => {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => {
        currentStep = currentStep >= 4 ? 1 : currentStep + 1;
        activateStep(currentStep);
      }, 15000);
    });
  </script>

  <!-- ============ REVIEWS STRIP ============ -->
  <section class="border-y border-stone-200/60 bg-white py-14 lg:py-20">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
            고객 후기
          </h2>
          <div class="mt-2 flex items-center gap-2">
            <div class="flex items-center gap-0.5">
              {[1, 2, 3, 4, 5].map(() => (
                <Icon name="lucide:star" class="size-5 fill-amber-400 text-amber-400" />
              ))}
            </div>
            <span class="text-sm font-medium text-stone-600">
              {(reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1)} 평균 ({reviews.length}개 리뷰)
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 flex gap-5 overflow-x-auto px-5 pb-4 lg:px-8 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      <div class="mx-auto flex max-w-7xl gap-5">
        {reviews.map((review) => (
          <div class="w-80 shrink-0 rounded-xl border border-stone-200/60 bg-stone-50 p-6">
            <div class="flex items-center gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <Icon
                  name="lucide:star"
                  class={`size-4 ${i < Math.floor(review.rating) ? 'fill-amber-400 text-amber-400' : 'text-stone-200'}`}
                />
              ))}
            </div>
            <p class="mt-3 text-sm leading-relaxed text-stone-600 line-clamp-4">
              "{review.text}"
            </p>
            <div class="mt-4 flex items-center gap-3">
              <div class="flex size-9 items-center justify-center rounded-full bg-brand-100 text-sm font-semibold text-brand-700">
                {review.author.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-semibold text-stone-800">{review.author}</p>
                <p class="text-xs text-stone-400">{new Date(review.date).toLocaleDateString('ko-KR', { month: 'long', year: 'numeric' })}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ AREAS SECTION ============ -->
  <section class="bg-stone-100 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="text-center">
        <h2 class="font-display text-3xl text-brand-900 sm:text-4xl">
          전국 서비스 지역
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-stone-600">
          {business.serviceRadius}까지 빠른 출동과 전문 서비스를 제공합니다.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {serviceAreas.map((area, i) => (
          <a
            href={areaUrl(area.slug)}
            class={`card-hover group rounded-xl border border-stone-200 bg-white p-6 animate-fade-up stagger-${Math.min(i + 1, 6)}`}
          >
            <div class="flex items-center gap-3">
              <Icon name="lucide:map-pin" class="size-5 text-brand-600" />
              <h3 class="font-display text-lg text-brand-900">{area.name}</h3>
            </div>
            <p class="mt-1 text-sm text-stone-500">{area.county}</p>
            <div class="mt-3 flex items-center gap-1.5 text-sm text-stone-600">
              <Icon name="lucide:clock" class="size-4 text-brand-500" />
              <span>{area.responseTime} 출동</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA BANNER ============ -->
  <section class="bg-brand-900">
    <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl text-white">배터리 교체가 필요하신가요?</h2>
          <p class="mt-2 text-brand-200">
            지금 바로 전화주시거나 온라인으로 문의하세요. 크고 작은 모든 배터리 문제를 해결해드립니다.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-6 py-3 text-sm font-semibold text-brand-950 shadow-lg transition-all hover:bg-amber-400"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone}
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
          >
            무료 견적 문의
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
