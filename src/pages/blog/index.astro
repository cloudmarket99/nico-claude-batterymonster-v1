---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { blogUrl } from '../../lib/urls';
import { business } from '../../data/business';
import { Icon } from 'astro-icon/components';
import { cases, caseUrl } from '../../data/cases';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const categoryColors: Record<string, { bg: string; text: string }> = {
  emergency: { bg: 'bg-red-100', text: 'text-red-700' },
  tips: { bg: 'bg-brand-100', text: 'text-brand-700' },
  maintenance: { bg: 'bg-amber-100', text: 'text-amber-700' },
  news: { bg: 'bg-stone-200', text: 'text-stone-700' },
};

const categoryLabels: Record<string, string> = {
  emergency: '긴급',
  tips: '팁',
  maintenance: '유지보수',
  news: '뉴스',
};

function formatDate(iso: string): string {
  const date = new Date(iso + 'T00:00:00');
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}


---

<BaseLayout
  title={`배터리 팁 & 뉴스 | ${business.name}`}
  description="산업용 배터리 관리 팁, 유지보수 가이드, 전국 배터리 서비스 뉴스. 밧데리몬스터 max의 전문 배터리 정보를 확인하세요."
>
  <Breadcrumbs crumbs={[{ label: '블로그' }]} />

  <section class="mx-auto max-w-7xl px-5 py-10 lg:px-8 lg:py-16">
    <div class="text-center">
      <h1 class="font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
        배터리 팁 & 뉴스
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-stone-600">
        산업용 배터리 관리 노하우, 수명 연장 팁, 최신 배터리 기술 정보를
        {business.name} 전문가가 알려드립니다.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="mt-12 text-center text-stone-500">
        블로그 포스트가 없습니다. 곧 유익한 정보를 업로드하겠습니다.
      </p>
    ) : (
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.slice(0, 9).map((post) => {
          const colors = categoryColors[post.data.category] || categoryColors.news;
          const label = categoryLabels[post.data.category] || post.data.category;
          return (
            <a
              href={blogUrl(post.id)}
              class="card-hover group flex flex-col overflow-hidden rounded-xl border border-stone-200 bg-white"
            >
              {post.data.image && (
                <div class="aspect-video overflow-hidden bg-stone-100">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center gap-3">
                  <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold ${colors.bg} ${colors.text}`}>
                    {label}
                  </span>
                  {post.data.readingTime && (
                    <span class="flex items-center gap-1 text-xs text-stone-400">
                      <Icon name="lucide:clock" class="size-3" />
                      {post.data.readingTime}
                    </span>
                  )}
                </div>

                <h2 class="mt-3 font-display text-lg text-brand-900 group-hover:text-brand-700">
                  {post.data.title}
                </h2>

                <p class="mt-2 flex-1 text-sm leading-relaxed text-stone-600 line-clamp-2">
                  {post.data.description}
                </p>

                <div class="mt-4 flex items-center gap-2 border-t border-stone-100 pt-4 text-xs text-stone-400">
                  <Icon name="lucide:calendar" class="size-3.5" />
                  <time datetime={post.data.publishDate}>
                    {formatDate(post.data.publishDate)}
                  </time>
                  <span class="text-stone-300">|</span>
                  <span>{post.data.author}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
