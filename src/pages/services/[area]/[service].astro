---
import { business, yearsInBusiness } from '../../../data/business';
import { serviceTypes } from '../../../data/serviceTypes';
import { serviceAreas, getNearbyAreas } from '../../../data/serviceAreas';
import type { ServiceType } from '../../../data/serviceTypes';
import type { ServiceArea } from '../../../data/serviceAreas';
import { serviceUrl, areaUrl, comboUrl, contactUrl } from '../../../lib/urls';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SeoFaq from '../../../components/SeoFaq.astro';
import SeoRelatedLinks from '../../../components/SeoRelatedLinks.astro';
import SeoServiceAreas from '../../../components/SeoServiceAreas.astro';
import SeoTestimonials from '../../../components/SeoTestimonials.astro';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  const paths = [];
  for (const area of serviceAreas) {
    for (const service of serviceTypes) {
      paths.push({
        params: { area: area.slug, service: service.slug },
        props: { area, service },
      });
    }
  }
  return paths;
}

interface Props {
  area: ServiceArea;
  service: ServiceType;
}

const { area, service } = Astro.props;
const years = yearsInBusiness();
const nearbyAreas = getNearbyAreas(area);
const nearbyNames = nearbyAreas.map((a) => a.name).join(', ');

const pageTitle = `${area.name} ${service.name} | ${business.name}`;
const pageDescription = `${area.name} ${service.name} 전문. ${business.name}이 ${area.responseTime} 이내 출동합니다. 전기공사업 면허 보유, 6개월 무상 A/S. 문의: ${business.phone}`;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${business.website}${comboUrl(area.slug, service.slug)}#service`,
      name: `${area.name} ${service.name}`,
      description: `${service.description} ${area.name}, ${area.county} 및 주변 지역 서비스.`,
      provider: {
        '@type': 'ElectricalContractor',
        '@id': `${business.website}/#business`,
        name: business.name,
        telephone: business.phone,
        url: business.website,
        address: {
          '@type': 'PostalAddress',
          addressLocality: business.address.city,
          addressRegion: business.address.state,
          addressCountry: 'KR',
        },
        geo: {
          '@type': 'GeoCoordinates',
          latitude: business.coordinates.lat,
          longitude: business.coordinates.lng,
        },
        founder: {
          '@type': 'Person',
          name: business.owner,
        },
        foundingDate: `${business.yearEstablished}`,
        hasCredential: {
          '@type': 'EducationalOccupationalCredential',
          credentialCategory: 'License',
          name: business.license,
        },
      },
      areaServed: [
        {
          '@type': 'City',
          name: area.name,
          containedInPlace: {
            '@type': 'AdministrativeArea',
            name: area.county,
          },
        },
      ],
      offers: {
        '@type': 'AggregateOffer',
        lowPrice: service.priceRange.min,
        highPrice: service.priceRange.max,
        priceCurrency: 'KRW',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '홈', item: business.website },
        { '@type': 'ListItem', position: 2, name: '서비스', item: `${business.website}/services/` },
        { '@type': 'ListItem', position: 3, name: area.name, item: `${business.website}${areaUrl(area.slug)}` },
        { '@type': 'ListItem', position: 4, name: service.name },
      ],
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={`${business.website}${comboUrl(area.slug, service.slug)}`}
  schema={schema}
>
  <Breadcrumbs
    crumbs={[
      { label: '서비스', href: '/services/' },
      { label: area.name, href: areaUrl(area.slug) },
      { label: service.name },
    ]}
  />

  <article class="mx-auto max-w-7xl px-5 lg:px-8">
    <!-- ============ HERO ============ -->
    <header class="pb-10 pt-6 lg:pt-10">
      <div class="lg:flex lg:items-start lg:gap-10">
        <div class="lg:flex-1">
          <div class="flex items-center gap-3 text-brand-600">
            <Icon name={service.icon} class="size-8" />
            <span class="text-sm font-semibold uppercase tracking-wide">
              전문 {service.name}
            </span>
          </div>
          <h1 class="mt-3 font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
            {area.name} {service.name}
          </h1>
          <p class="mt-4 max-w-3xl text-lg leading-relaxed text-stone-600">
            {pageDescription}
          </p>
        </div>
        <div class="mt-6 lg:mt-0 lg:w-80 lg:shrink-0">
          <img
            src={service.image}
            alt={`${area.name} ${service.name}`}
            class="rounded-xl shadow-lg"
            width="1024"
            height="1024"
            loading="eager"
          />
        </div>
      </div>
    </header>

    <!-- ============ SERVICE IMAGE ============ -->
    <div class="mb-10 overflow-hidden rounded-xl">
      <img
        src={service.image}
        alt={`${area.name} ${service.name} 서비스`}
        class="h-64 w-full object-cover sm:h-80 lg:h-96"
        width="1408"
        height="768"
        loading="eager"
      />
    </div>

    <!-- ============ EMERGENCY ALERT BANNER ============ -->
    {service.emergency && (
      <div class="mb-10 flex items-center gap-4 rounded-xl border border-amber-200 bg-amber-50 p-5">
        <div class="flex size-12 shrink-0 items-center justify-center rounded-full bg-amber-100">
          <Icon name="lucide:zap" class="size-6 text-amber-600" />
        </div>
        <div>
          <p class="font-semibold text-amber-900">
            {area.name} 긴급 {service.name} 24시간 출동
          </p>
          <p class="mt-1 text-sm text-amber-700">
            배터리 긴급 상황은 기다릴 수 없습니다. {area.name} 및 주변 지역에 언제든지 즉시 출동합니다.
          </p>
        </div>
        <a
          href={business.phoneHref}
          class="ml-auto hidden shrink-0 items-center gap-2 rounded-lg bg-amber-500 px-5 py-2.5 text-sm font-semibold text-white shadow transition-colors hover:bg-amber-600 sm:inline-flex"
        >
          <Icon name="lucide:phone" class="size-4" />
          즉시 전화
        </a>
      </div>
    )}

    <!-- ============ DESCRIPTION SECTION ============ -->
    <section class="prose-editorial max-w-3xl pb-12">
      <h2>{area.name} {service.name} 전문 서비스</h2>
      <p>
        {service.description}
      </p>
      <p>
        {business.name}은 {area.name}과 {area.county} 지역에서 {years}년 이상 산업용 배터리 서비스를 제공해 왔습니다.
        {area.description}
      </p>
      {nearbyAreas.length > 0 && (
        <p>
          {area.name} 외에도 인근 지역인 {nearbyNames} 등에도 {service.name} 서비스를 제공합니다.
          전 지역 신속한 출동과 전문적인 기술로 믿을 수 있는 서비스를 보장합니다.
        </p>
      )}
    </section>

    <!-- ============ PRICE SECTION ============ -->
    <section class="pb-12">
      <div class="rounded-xl border border-stone-200 bg-white p-8 lg:p-10">
        <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
          {area.name} {service.name} 비용은?
        </h2>
        <div class="mt-6 flex items-baseline gap-2">
          <span class="font-display text-4xl text-brand-700">
            {service.priceRange.min.toLocaleString()}원
          </span>
          <span class="text-2xl text-stone-400">&ndash;</span>
          <span class="font-display text-4xl text-brand-700">
            {service.priceRange.max.toLocaleString()}원
          </span>
        </div>
        <p class="mt-3 text-sm text-stone-500">
          {area.name} 지역 {service.name} 예상 비용입니다. 작업 규모, 배터리 사양, 현장 조건에 따라 달라질 수 있습니다.
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <div class="flex items-center gap-2 text-sm text-stone-600">
            <Icon name="lucide:check-circle" class="size-5 text-brand-600" />
            <span>무료 현장 견적</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-stone-600">
            <Icon name="lucide:check-circle" class="size-5 text-brand-600" />
            <span>숨겨진 비용 없음</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-stone-600">
            <Icon name="lucide:check-circle" class="size-5 text-brand-600" />
            <span>작업 전 견적 확정</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PROCESS STEPS ============ -->
    <section class="pb-16">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
        {service.name} 작업 과정
      </h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        명확하고 검증된 프로세스로 진행합니다.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {service.processSteps.map((step, index) => (
          <div class="relative rounded-xl border border-stone-200 bg-white p-6">
            <div class="mb-4 flex size-10 items-center justify-center rounded-full bg-brand-50 font-display text-lg text-brand-700">
              {index + 1}
            </div>
            <h3 class="font-display text-lg text-brand-900">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ WHY CHOOSE US ============ -->
    <section class="pb-16">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
        {area.name}에서 {business.name}을 선택하는 이유
      </h2>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-stone-200 bg-white p-6 text-center">
          <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-brand-50">
            <Icon name="lucide:shield-check" class="size-6 text-brand-700" />
          </div>
          <h3 class="mt-4 font-semibold text-brand-900">면허 보유</h3>
          <p class="mt-2 text-sm text-stone-600">
            전기공사업 면허 및 ISO 9001 인증. 모든 현장 배상 책임보험 가입.
          </p>
        </div>

        <div class="rounded-xl border border-stone-200 bg-white p-6 text-center">
          <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-brand-50">
            <Icon name="lucide:map-pin" class="size-6 text-brand-700" />
          </div>
          <h3 class="mt-4 font-semibold text-brand-900">전국 서비스</h3>
          <p class="mt-2 text-sm text-stone-600">
            {years}년 이상 전국 산업 현장에 배터리 서비스 제공. {area.name}도 당연히 서비스 지역입니다.
          </p>
        </div>

        <div class="rounded-xl border border-stone-200 bg-white p-6 text-center">
          <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-brand-50">
            <Icon name="lucide:clock" class="size-6 text-brand-700" />
          </div>
          <h3 class="mt-4 font-semibold text-brand-900">빠른 출동</h3>
          <p class="mt-2 text-sm text-stone-600">
            {area.name} {area.responseTime} 출동. 당일 서비스 가능.
          </p>
        </div>

        <div class="rounded-xl border border-stone-200 bg-white p-6 text-center">
          <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-brand-50">
            <Icon name="lucide:badge-check" class="size-6 text-brand-700" />
          </div>
          <h3 class="mt-4 font-semibold text-brand-900">무상 A/S 보장</h3>
          <p class="mt-2 text-sm text-stone-600">
            모든 배터리 교체 및 설치 작업에 6개월 무상 A/S를 제공합니다.
          </p>
        </div>
      </div>
    </section>

    <!-- ============ CTA SECTION ============ -->
    <section class="pb-16">
      <div class="rounded-2xl bg-gradient-to-br from-brand-900 to-brand-800 p-8 text-center lg:p-12">
        <h2 class="font-display text-2xl text-white sm:text-3xl">
          {area.name} {service.name} 예약하기
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-brand-200">
          긴급 교체나 일반 서비스 예약 모두 환영합니다.
          지금 바로 연락하시면 빠르게 도움드리겠습니다.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-6 py-3 text-sm font-semibold text-brand-950 shadow-lg transition-all hover:bg-amber-400 hover:shadow-xl"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone} 전화상담
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition-all hover:bg-white/20"
          >
            <Icon name="lucide:message-square" class="size-5" />
            무료 견적 문의
          </a>
        </div>
      </div>
    </section>

    <!-- ============ SEO COMPONENTS ============ -->
    <section class="pb-8">
      <SeoRelatedLinks area={area} service={service} />
    </section>

    <section class="pb-8">
      <SeoServiceAreas currentArea={area} service={service} />
    </section>

    <SeoTestimonials area={area} service={service} />
  </article>

  <SeoFaq area={area} service={service} />
</BaseLayout>
