---
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../../data/business';
import { serviceTypes, getServiceBySlug } from '../../data/serviceTypes';
import { serviceAreas, getAreaBySlug } from '../../data/serviceAreas';
import { serviceUrl, areaUrl, comboUrl, contactUrl } from '../../lib/urls';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SeoFaq from '../../components/SeoFaq.astro';

import type { ServiceType } from '../../data/serviceTypes';

export function getStaticPaths() {
  return serviceTypes.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

interface Props {
  service: ServiceType;
}

const { service } = Astro.props;

const seoulArea = getAreaBySlug('seoul')!;

const pageTitle = `${service.name} | 전국 산업용 배터리 전문`;
const metaDescription = service.description.length > 155
  ? service.description.slice(0, 152) + '...'
  : service.description;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.name,
  description: service.description,
  provider: {
    '@type': 'ElectricalContractor',
    name: business.name,
    telephone: business.phone,
    url: business.website,
    address: {
      '@type': 'PostalAddress',
      addressLocality: business.address.city,
      addressRegion: business.address.state,
      addressCountry: 'KR',
    },
  },
  areaServed: serviceAreas.map((area) => ({
    '@type': 'City',
    name: area.name,
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: area.county,
    },
  })),
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      priceCurrency: 'KRW',
      minPrice: service.priceRange.min,
      maxPrice: service.priceRange.max,
    },
  },
};
---

<BaseLayout title={pageTitle} description={metaDescription} schema={schema}>
  <Breadcrumbs
    crumbs={[
      { label: '서비스', href: '/services/' },
      { label: service.name },
    ]}
  />

  <!-- Hero section -->
  <section class="mx-auto max-w-7xl px-5 pb-12 pt-8 lg:px-8">
    <div class="lg:flex lg:items-start lg:gap-12">
      <div class="lg:flex-1">
        {service.emergency && (
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-red-50 px-4 py-2 text-sm font-medium text-red-700 ring-1 ring-red-200/60">
            <Icon name="lucide:alert-circle" class="size-4 text-red-500" />
            24시간 긴급 출동 가능
          </div>
        )}

        <h1 class="font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
          {pageTitle}
        </h1>

        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-stone-600">
          {service.description}
        </p>

        <div class="mt-6 inline-flex items-center gap-2 rounded-lg bg-brand-50 px-5 py-3 text-sm font-medium text-brand-800 ring-1 ring-brand-200/60">
          <Icon name="lucide:credit-card" class="size-4 text-brand-500" />
          예상 비용: {service.priceRange.min.toLocaleString()}원 ~ {service.priceRange.max.toLocaleString()}원
        </div>
      </div>

      <div class="mt-8 lg:mt-0 lg:w-96 lg:shrink-0">
        <img
          src={service.image}
          alt={`${service.name} 서비스 - ${business.name}`}
          class="rounded-xl shadow-lg"
          width="1024"
          height="1024"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Process steps section -->
  <section class="border-t border-stone-200/60 bg-white py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
        {service.name} 진행 과정
      </h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        처음부터 끝까지 명확한 프로세스로 진행합니다.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {service.processSteps.map((step, index) => (
          <div class="relative rounded-xl border border-stone-200/60 bg-stone-50 p-6">
            <div class="flex size-10 items-center justify-center rounded-full bg-brand-800 text-sm font-bold text-white">
              {index + 1}
            </div>

            <h3 class="mt-4 text-base font-semibold text-stone-900">
              {step.title}
            </h3>

            <p class="mt-2 text-sm leading-relaxed text-stone-600">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas we serve for this service -->
  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
      {service.name} 서비스 지역
    </h2>
    <p class="mt-3 max-w-2xl text-stone-600">
      전국 주요 지역에 {service.name} 서비스를 제공합니다. 지역을 선택하면 해당 지역 가격과 출동 정보를 확인하실 수 있습니다.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {serviceAreas.map((area) => (
        <a
          href={comboUrl(area.slug, service.slug)}
          class="group rounded-xl border border-stone-200/60 bg-white p-5 transition-all hover:border-brand-200 hover:shadow-md"
        >
          <div class="flex items-center gap-3">
            <Icon name="lucide:map-pin" class="size-5 text-brand-500" />
            <span class="font-semibold text-stone-800 group-hover:text-brand-800">
              {area.name}
            </span>
          </div>
          <p class="mt-2 text-sm text-stone-500">
            {area.county}
          </p>
          <p class="mt-1 text-xs text-stone-400">
            출동 시간: {area.responseTime}
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ section -->
  <div class="border-t border-stone-200/60 bg-white">
    <SeoFaq area={seoulArea} service={service} />
  </div>

  <!-- CTA section -->
  <section class="bg-brand-900 py-16">
    <div class="mx-auto max-w-4xl px-5 text-center lg:px-8">
      <h2 class="font-display text-2xl text-white sm:text-3xl">
        {service.name}이 필요하신가요?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-brand-200">
        {business.name}은 {yearsInBusiness()}년 이상의 경험으로 전국 산업 현장에 신속하고 안전한 배터리 서비스를 제공합니다.
        지금 바로 무료 견적을 받아보세요.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-brand-900 shadow-sm transition-all hover:bg-stone-100 hover:shadow-md"
        >
          <Icon name="lucide:phone" class="size-4" />
          {business.phone}
        </a>
        <a
          href={contactUrl()}
          class="inline-flex items-center gap-2 rounded-lg border border-brand-300/40 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-brand-800"
        >
          <Icon name="lucide:mail" class="size-4" />
          무료 견적 문의
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
